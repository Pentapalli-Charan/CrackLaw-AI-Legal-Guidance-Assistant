# ============================================
# CrackLaw Environment Variables
# ============================================
# Copy this file to .env and fill in your API key.
# You only need ONE provider key — whichever you want to use.

# ---- LLM Provider API Keys (set at least one) ----
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

# ---- Ollama (local, no key needed) ----
# OLLAMA_HOST=http://localhost:11434

# ---- CrackLawLM (local, no key needed, set in config.json as llm_provider: "cracklaw") ----

# ---- CrackLaw API Authentication (optional) ----
# CRACKLAW_API_KEY=
